<!DOCTYPE html>
<html lang="de">

<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Für dich</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
}

body{

display:flex;
justify-content:center;
align-items:flex-end;

height:100vh;

background:#0b0e16;

overflow:hidden;

font-family:Inter, sans-serif;

}

/* background glow */

body::before{

content:"";

position:absolute;

width:600px;
height:600px;

background:radial-gradient(circle,#1b2735,#090a0f);

top:50%;
left:50%;

transform:translate(-50%,-50%);

filter:blur(120px);

}

/* garden container */

.garden{

position:relative;

display:flex;

gap:120px;

align-items:flex-end;

}

/* flower */

.flower{

position:relative;

display:flex;

flex-direction:column;

align-items:center;

animation:sway 4s ease-in-out infinite;

}

/* stem */

.stem{

width:6px;
height:0;

background:linear-gradient(#2ecc71,#145a32);

border-radius:4px;

animation:growStem 2s ease forwards;

}

/* petals */

.petals{

position:absolute;

top:-60px;

display:grid;

grid-template-columns:repeat(3,40px);

gap:4px;

opacity:0;

animation:bloom 1.5s ease forwards;
animation-delay:2s;

}

.petal{

width:40px;
height:40px;

background:radial-gradient(circle,#ff7aa5,#e8437a);

border-radius:50%;

}

/* center */

.center{

position:absolute;

top:-40px;

width:30px;
height:30px;

background:#ffd54f;

border-radius:50%;

box-shadow:0 0 20px rgba(255,213,79,0.8);

opacity:0;

animation:fadeCenter 1s ease forwards;
animation-delay:2.5s;

}

/* animations */

@keyframes growStem{

0%{
height:0;
}

100%{
height:220px;
}

}

@keyframes bloom{

0%{
transform:scale(0);
opacity:0;
}

100%{
transform:scale(1);
opacity:1;
}

}

@keyframes fadeCenter{

from{
opacity:0;
transform:scale(0);
}

to{
opacity:1;
transform:scale(1);
}

}

@keyframes sway{

0%,100%{
transform:rotate(-2deg);
}

50%{
transform:rotate(2deg);
}

}

</style>

</head>

<body>

<div class="garden">

<div class="flower">

<div class="stem"></div>

<div class="petals">
<div class="petal"></div>
<div class="petal"></div>
<div class="petal"></div>
<div class="petal"></div>
<div class="petal"></div>
<div class="petal"></div>
<div class="petal"></div>
<div class="petal"></div>
<div class="petal"></div>
</div>

<div class="center"></div>

</div>

<div class="flower">

<div class="stem"></div>

<div class="petals">
